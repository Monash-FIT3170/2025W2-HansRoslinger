{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Interactive bar chart",
  "data": {
    "values": [
      { "a": "A", "b": 28 },
      { "a": "B", "b": 55 },
      { "a": "C", "b": 43 },
      { "a": "D", "b": 91 },
      { "a": "E", "b": 81 },
      { "a": "F", "b": 53 },
      { "a": "G", "b": 19 },
      { "a": "H", "b": 87 },
      { "a": "I", "b": 52 }
    ]
  },
  "selection": {
    "highlight": {
      "type": "single",
      "on": "mouseover",
      "empty": "all",
      "fields": ["a"]
    },
    "grid": {
      "type": "interval",
      "bind": "scales"
    }
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "a",
      "type": "nominal",
      "axis": { "labelAngle": 0 }
    },
    "y": {
      "field": "b",
      "type": "quantitative"
    },
    "opacity": {
      "condition": { "selection": "highlight", "value": 1 },
      "value": 0.4
    },
    "tooltip": [
      { "field": "a", "type": "nominal", "title": "Category" },
      { "field": "b", "type": "quantitative", "title": "Value" }
    ]
  }
}
